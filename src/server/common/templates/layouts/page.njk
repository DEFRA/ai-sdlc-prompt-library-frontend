{% extends "govuk/template.njk" %}

{% from "govuk/components/breadcrumbs/macro.njk" import govukBreadcrumbs %}

{# Import custom components globally #}
{% from "heading/macro.njk" import appHeading %}

{% set htmlClasses = "govuk-template govuk-template--rebranded" %}
{% set mainClasses = "app-main-wrapper" %}

{% block head %}
  <link href="{{ getAssetPath('stylesheets/application.scss') }}" rel="stylesheet">
{% endblock %}

{% block header %}
  <header class="defra-header" role="banner">
    <div class="defra-header__inner">
      <a href="/">
        <img class="defra-header__logo" src="/public/assets/images/defra-logo.svg" alt="Department for Environment, Food &amp; Rural Affairs">
      </a>
      <a href="/" class="defra-header__service-name">AI Capabilities and Enablement</a>
    </div>
  </header>

  <nav class="defra-service-navigation" aria-label="Service navigation">
    <div class="defra-service-navigation__inner">
      <ul class="defra-service-navigation__list">
        {% for item in navigation %}
          <li>
            <a class="defra-service-navigation__link"
               href="{{ item.href }}"
               {% if item.current %}aria-current="page"{% endif %}>
              {{ item.text }}
            </a>
          </li>
        {% endfor %}
      </ul>
    </div>
  </nav>
{% endblock %}

{% block pageTitle %}
  {{ pageTitle }} | {{ serviceName }}
{% endblock %}

{% block beforeContent %}
  {% if breadcrumbs.length > 1 %}
    {{ govukBreadcrumbs({
      items: breadcrumbs
    }) }}
  {% endif %}
{% endblock %}

{% block content %}{% endblock %}

{% block footer %}
  <footer class="defra-footer" role="contentinfo">
    <div class="govuk-width-container">
      <ul class="govuk-list" style="display:flex;gap:24px;margin:0;flex-wrap:wrap;">
        <li><a class="defra-footer__link" href="https://www.gov.uk/help/privacy-notice">Privacy</a></li>
        <li><a class="defra-footer__link" href="https://www.gov.uk/help/cookies">Cookies</a></li>
        <li><a class="defra-footer__link" href="https://www.gov.uk/help/accessibility-statement">Accessibility statement</a></li>
      </ul>
      <p class="govuk-body-s govuk-!-margin-top-3 govuk-!-margin-bottom-0" style="color:#505a5f;">
        &copy; Crown copyright
      </p>
    </div>
  </footer>
{% endblock %}

{% block bodyEnd %}
  <script type="module" src="{{ getAssetPath('application.js') }}"></script>
{% endblock %}

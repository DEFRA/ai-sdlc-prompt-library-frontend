<h1 class="govuk-heading-l">{{ entry.title }}</h1>

<h2 class="govuk-heading-m">What this is</h2>
<p class="govuk-body">{{ entry.whatThisIs }}</p>

<h2 class="govuk-heading-m">When to use this</h2>
<p class="govuk-body">{{ entry.whenToUseThis }}</p>

<h2 class="govuk-heading-m">What&#39;s inside</h2>
<p class="govuk-body">{{ entry.whatsInside }}</p>

<a href="{{ entry.repositoryUrl }}"

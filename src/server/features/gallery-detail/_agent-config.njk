<h1 class="govuk-heading-l">{{ entry.title }}</h1>

<h2 class="govuk-heading-m">Design philosophy</h2>
<p class="govuk-body">{{ entry.designPhilosophy }}</p>

{% if entry.keyFeatures.length %}
  <h2 class="govuk-heading-m">Key features</h2>
  <ul class="govuk-list govuk-list--bullet">
    {% for feature in entry.keyFeatures %}
      <li>{{ feature }}</li>
    {% endfor %}
  </ul>
{% endif %}

{% if entry.whoThisIsFor.length %}
  <h2 class="govuk-heading-m">Who this is for</h2>
  <ul class="govuk-list govuk-list--bullet">
    {% for item in entry.whoThisIsFor %}
      <li>{{ item }}</li>
    {% endfor %}
  </ul>
{% endif %}

<a href="{{ entry.repositoryUrl }}"
   class="govuk-button govuk-button--start"
   target="_blank"
   rel="noopener noreferrer"
   role="button">
  View repository
  <span class="govuk-visually-hidden">(opens in new tab)</span>
  <svg class="govuk-button__start-icon" xmlns="http://www.w3.org/2000/svg" width="17.5" height="19" viewBox="0 0 33 40" aria-hidden="true" focusable="false">
    <path fill="currentColor" d="M0 0h13l20 20-20 20H0l20-20z"/>
  </svg>
</a>

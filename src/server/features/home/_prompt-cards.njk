<section class="defra-section" aria-label="Prompt gallery">
  {% if galleryCards.length %}
    <ul class="defra-tile-grid">
      {% for card in galleryCards %}
        <li>
          <div class="defra-tile">
            <strong class="govuk-tag
              {% if card.typeBadge === 'Prompt' %}govuk-tag--blue
              {% elif card.typeBadge === 'Workflow' %}govuk-tag--purple
              {% elif card.typeBadge === 'Repository' %}govuk-tag--green
              {% endif %}"
              aria-label="Type: {{ card.typeBadge }}">
              {{ card.typeBadge }}
            </strong>
            <h3 class="govuk-heading-m defra-tile__title">
              <a class="defra-tile__link" href="{{ card.href }}">{{ card.title }}</a>
            </h3>
            <p class="govuk-body defra-tile__body">{{ card.summary }}</p>
          </div>
        </li>
      {% endfor %}
    </ul>
  {% else %}
    <p class="govuk-body">There are no entries yet. Check back soon.</p>
  {% endif %}
</section>

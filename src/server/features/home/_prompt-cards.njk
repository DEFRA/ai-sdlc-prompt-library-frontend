<section class="defra-section" aria-labelledby="prompts-heading">
  <h2 class="govuk-heading-l" id="prompts-heading">Featured prompts</h2>
  <ul class="govuk-grid-row defra-tile-grid">
    {% for card in promptCards %}
      <li class="govuk-grid-column-one-third">
        <div class="defra-tile">
          <h3 class="govuk-heading-m defra-tile__title">
            {% if card.href %}
              <a class="defra-tile__link" href="{{ card.href }}">{{ card.title }}</a>
            {% else %}
              {{ card.title }}
            {% endif %}
          </h3>
          {% if card.body %}
            <p class="govuk-body-s defra-tile__body">{{ card.body }}</p>
          {% endif %}
        </div>
      </li>
    {% endfor %}
  </ul>
</section>
